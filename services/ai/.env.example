# Copy to .env, then set OPENAI_API_KEY. The chain settings below default to the shared
# testnet deployment and work as-is on a machine that has run `pnpm contract:deploy`
# (which creates the kolektibo-* Stellar CLI identities and builds the contract wasm).

# ── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=8787

# ── Chain ops (no secrets — the deployer/issuer live in the local Stellar CLI keystore) ──
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Shared testnet USDC (Stellar Asset Contract) + its classic issuer:
USDC_SAC_ID=CDTCIZLKSZNDFDSZRQUFIHQ5P5L2OOI5DDOMSY5NH6NQQTGSOE5LK7QR
USDC_ISSUER=GBYFIFSFQUE6M4O4ESBX7I4FU2XXPRI3V47C2BONMZBG6VKYCBSG55HM

# Stellar CLI identity names used to mint / deploy (created by `pnpm contract:deploy`):
ISSUER_IDENTITY=kolektibo-usdc-issuer
DEPLOYER_IDENTITY=kolektibo-deployer

# Machine-specific paths — adjust to this machine:
#   Windows default shown; on macOS/Linux this is usually just "stellar" if on PATH.
STELLAR_BIN=C:/Program Files (x86)/Stellar CLI/stellar.exe
#   The built contract wasm (produced by `pnpm contract:build`):
TREASURY_WASM_PATH=../../contracts/target/wasm32v1-none/release/treasury.wasm

# ── SDK backend (E3 — server-only secrets; use KMS in production) ────────────
# Default off through Jul 15 — CLI path stays the demo default on main.
# USE_SDK_BACKEND=1
# Export once from the CLI keystore: `stellar keys secret kolektibo-deployer`
# DEPLOYER_SECRET=
# ISSUER_SECRET=
# Optional — skip wasm hash/upload on restart (logged on first upload):
# TREASURY_WASM_HASH=

# ── HTTP hardening (optional) ──────────────────────────────────────────────────
# Restrict browser origin when set; unset = open CORS (local dev default).
# CORS_ORIGIN=http://localhost:5173
# Trust X-Forwarded-For for rate-limit keys only behind a known reverse proxy.
# TRUST_PROXY=1

# ── Email + Supabase (server-only; NEVER expose to the browser / no VITE_ prefix) ──
# Gmail SMTP for verification + reset codes. Use a Gmail APP PASSWORD (16 chars, requires
# 2-Step Verification), NOT your normal account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Supabase service role — full DB access, keep secret (Project Settings → API):
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Peppers the hashed 6-digit codes — any long random string:
CODE_PEPPER=
