{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "express",
  "installCommand": "npm install",
  "functions": {
    "src/index.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/agent/worker/tick",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/internal/indexer/tick",
      "schedule": "5 0 * * *"
    }
  ]
}
